# Personal profile for form auto-filling
# Fill in your details below. Leave fields blank if not applicable.

personal:
  first_name: ""
  last_name: ""
  email: ""
  phone: ""
  organization: ""  # Current or most recent employer/organization
  address:
    street: ""
    city: ""
    postal_code: ""
    country: "Sweden"

professional:
  title: ""  # e.g. "Software Developer"
  summary: ""  # Brief professional summary

links:
  linkedin: ""
  github: ""
  website: ""

# Predefined answers for common form questions
# These are matched by keywords in field labels/names
form_answers:
  # Language skills - matched when a field label contains the language name
  # Values: "Yes", "No", or a proficiency level like "Fluent", "Native", "Basic"
  languages:
    swedish: "Fluent"
    english: "Fluent"

  # Yes/No answers - matched when a field label contains the keyword
  # Use for questions like "Do you have a drivers license?", "Willing to relocate?"
  yes_no:
    # drivers_license: "Yes"
    # relocate: "Yes"
    # work_permit: "Yes"
    # eu_citizen: "Yes"
    # skallkrav and meriterande are auto-answered "Yes" by default (built-in).
    # Override here only if you want a different answer:
    # skallkrav: "Yes"
    # meriterande: "Yes"

  # Freeform answers - matched when a field label contains the keyword
  # Use for short text fields like "Expected salary", "Available from"
  text:
    # salary: "Negotiable"
    # lönanspråk: "Negotiable"          # Swedish: expected salary
    # availability: "Immediately"
    # notice_period: "1 month"
    # uppsägningstid: "1 månad"         # Swedish: notice period
    # tidigast_tillgänglig: "Omgående"  # Swedish: earliest availability
